{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Storyboard Schema",
  "description": "Структурированная раскадровка короткого видеоролика. Используется storyboarder-агентом на выходе и читается image-gen / video-gen на входе.",
  "type": "object",
  "required": ["job_id", "duration_sec", "aspect", "shots"],
  "properties": {
    "job_id": {
      "type": "string",
      "description": "Уникальный slug проекта (используется как имя папки drafts/<job_id>/)"
    },
    "duration_sec": {
      "type": "integer",
      "minimum": 10,
      "maximum": 180
    },
    "aspect": {
      "type": "string",
      "enum": ["9:16", "16:9", "1:1", "3:4", "4:3"]
    },
    "style_anchor": {
      "type": "string",
      "description": "Блок prompt'а для единого визуального стиля (вшивается в final_prompt каждого shot'а с person)"
    },
    "shots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "timing", "sketch_prompt", "final_prompt"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^shot_[0-9]{2}$",
            "description": "shot_01, shot_02, ..."
          },
          "timing": {
            "type": "string",
            "pattern": "^[0-9]+:[0-9]{2}\\u2013[0-9]+:[0-9]{2}$",
            "description": "например '0:00–0:04'"
          },
          "duration_sec": {
            "type": "integer",
            "minimum": 1,
            "maximum": 15
          },
          "composition": {
            "type": "string",
            "enum": ["wide establishing", "wide", "medium", "close-up", "extreme close-up", "macro", "POV", "overhead"]
          },
          "sketch_prompt": {
            "type": "string",
            "description": "B&W pencil sketch prompt для этапа одобрения (модель nano-banana-fast, 1K)"
          },
          "final_prompt": {
            "type": "string",
            "description": "Цветной final prompt (модель nano-banana-pro, 2K)"
          },
          "motion_prompt": {
            "type": "string",
            "description": "Описание движения камеры/объектов для i2v (Kling)"
          },
          "has_face": {
            "type": "boolean",
            "default": false
          },
          "face_ref": {
            "type": "string",
            "description": "URL канонического face REF (если has_face=true)"
          },
          "narration": {
            "type": "string",
            "description": "Текст voice-over для этого shot'а"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "sketched", "approved", "rendered", "final", "rejected"],
            "default": "pending"
          }
        }
      }
    }
  }
}
